---
// src/pages/login.astro
export const prerender = false;

import BaseLayout from "../layouts/BaseLayout.astro";

const API_URL = import.meta.env.PUBLIC_API_URL ?? "http://localhost:3000";
const isProd = import.meta.env.PROD;

const nextUrlRaw = Astro.url.searchParams.get("next") ?? "/account";
const nextUrl =
  nextUrlRaw.startsWith("/") && !nextUrlRaw.startsWith("//") ? nextUrlRaw : "/account";

let error = "";

if (Astro.request.method === "POST") {
  const form = await Astro.request.formData();
  const email = String(form.get("email") ?? "").trim();
  const password = String(form.get("password") ?? "");

  if (!email || !password) {
    error = "Ingresa email y password.";
  } else {
    const res = await fetch(`${API_URL}/auth/login`, {
      method: "POST",
      headers: { "Content-Type": "application/json", Accept: "application/json" },
      body: JSON.stringify({ email, password }),
    });

    if (!res.ok) {
      const body = await res.json().catch(() => null);
      error = body?.message ?? `Login failed (${res.status})`;
    } else {
      const data = await res.json().catch(() => ({}));
      const token = String(data?.accessToken ?? "");

      if (!token) {
        error = "Login failed: missing accessToken";
      } else {
        Astro.cookies.set("adi_token", token, {
          httpOnly: true,
          sameSite: "lax",
          secure: isProd,
          path: "/",
          maxAge: 60 * 60 * 24 * 7,
        });

        // ✅ ya NO usamos adi_user
        Astro.cookies.delete("adi_user", { path: "/", secure: isProd, sameSite: "lax" });

        return Astro.redirect(nextUrl);
      }
    }
  }
}
---

<BaseLayout title="ADI — Login">
  <section class="adi-section">
    <div class="container" style="max-width: 520px;">
      <div class="adi-card p-4 p-md-5">
        <div class="text-center mb-4">
          <div class="adi-soft small">ADI</div>
          <h1 class="fw-bold mb-1">Iniciar sesión</h1>
          <div class="adi-soft">Accede a tu cuenta y pedidos.</div>
        </div>

        {error && <div class="alert alert-danger mb-3" role="alert">{error}</div>}

        <form method="post" class="d-grid gap-3">
          <div>
            <label class="form-label">Email</label>
            <input class="form-control" name="email" type="email" required autocomplete="email" />
          </div>

          <div>
            <label class="form-label">Password</label>
            <input class="form-control" name="password" type="password" required autocomplete="current-password" />
          </div>

          <button class="btn btn-primary w-100" type="submit">Entrar</button>

          <a class="btn btn-outline-light w-100" href="/catalogo">Volver al catálogo</a>
        </form>
      </div>

      <div class="text-center mt-3 adi-soft small">
        Tip: si eres admin, tendrás acceso a Bulk Upload.
      </div>
    </div>
  </section>
</BaseLayout>