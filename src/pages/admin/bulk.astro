---
export const prerender = false;

import BaseLayout from "../../layouts/BaseLayout.astro";

const API_URL = import.meta.env.PUBLIC_API_URL ?? "http://localhost:3000";
const isProd = import.meta.env.PROD;

const nextPath = "/admin/bulk";

// SSR cookie header (más confiable)
const cookieHeader = Astro.request.headers.get("cookie") ?? "";
const tokenMatch = cookieHeader.match(/(?:^|;\s*)adi_token=([^;]+)/);
const token = tokenMatch ? decodeURIComponent(tokenMatch[1]) : null;

// base64url -> json
function decodeJwtPayloadSSR(jwt: string): any | null {
  try {
    const parts = jwt.split(".");
    if (parts.length < 2) return null;

    const payloadB64Url = parts[1];
    const pad = "=".repeat((4 - (payloadB64Url.length % 4)) % 4);
    const b64 = (payloadB64Url + pad).replace(/-/g, "+").replace(/_/g, "/");

    const json =
      typeof atob === "function"
        ? atob(b64)
        : Buffer.from(b64, "base64").toString("utf8");

    return JSON.parse(json);
  } catch {
    return null;
  }
}

// role robusto (soporta ROLE_ADMIN, roles[], user.role)
function extractRole(payload: any): "admin" | "user" {
  const raw =
    payload?.role ??
    payload?.user?.role ??
    payload?.roles?.[0] ??
    payload?.user?.roles?.[0] ??
    null;

  if (!raw) return "user";
  const s = String(raw).toLowerCase();
  return s.includes("admin") ? "admin" : "user";
}

// valida exp si existe
function isTokenExpired(payload: any): boolean {
  const exp = payload?.exp;
  if (!exp) return false; // si no hay exp, no lo marcamos como expirado
  const nowSec = Math.floor(Date.now() / 1000);
  return Number(exp) <= nowSec;
}

function logoutAndRedirect() {
  // borra cookies (asegura path /)
  Astro.cookies.delete("adi_token", { path: "/", secure: isProd, sameSite: "lax" });
  Astro.cookies.delete("adi_user", { path: "/", secure: isProd, sameSite: "lax" });

  return Astro.redirect(`/login?next=${encodeURIComponent(nextPath)}`);
}

let payload: any | null = null;
let role: "admin" | "user" = "user";
let emailForUi: string | null = null;

if (!token) {
  return logoutAndRedirect();
}

payload = decodeJwtPayloadSSR(token);
if (!payload) {
  return logoutAndRedirect();
}

if (isTokenExpired(payload)) {
  return logoutAndRedirect();
}

role = extractRole(payload);
if (role !== "admin") {
  return logoutAndRedirect();
}

emailForUi = payload?.email ?? payload?.user?.email ?? null;

// opcional: si quieres confiar en middleware cuando ya funcione,
// puedes usar Astro.locals.user para UI; pero aquí usamos payload.
---

<BaseLayout title="ADI — Admin Bulk" menuMode="b2c" menuAnchors={false}>
  <section class="adi-section">
    <div class="container" style="max-width: 980px;">
      <div class="d-flex align-items-start justify-content-between gap-3 flex-wrap mb-3">
        <div>
          <div class="adi-soft small">Admin</div>
          <h1 class="fw-bold mb-1">Bulk Upload</h1>
          <div class="adi-soft">
            Sube el Excel y las imágenes referenciadas en <code>imageFiles</code>.
          </div>
          <div class="adi-soft small mt-1">
            Sesión: {emailForUi ?? "admin"} · rol: <span class="fw-semibold">{role}</span>
          </div>
        </div>

        <a class="btn btn-outline-light" href="/account">Volver a cuenta</a>
      </div>

      <div class="row g-3">
        <div class="col-12 col-lg-6">
          <div class="adi-card p-3 p-md-4">
            <h2 class="h5 fw-bold mb-2">Subir archivos</h2>
            <div class="adi-soft small mb-3">
              El campo de imágenes es opcional. Puedes subir múltiples.
            </div>

            <form id="bulkForm" class="d-grid gap-3">
              <div>
                <label class="form-label">Excel (.xlsx)</label>
                <input class="form-control" name="file" type="file" accept=".xlsx" required />
              </div>

              <div>
                <label class="form-label">Imágenes (multiple)</label>
                <input class="form-control" name="images" type="file" accept="image/*" multiple />
              </div>

              <button class="btn btn-primary" type="submit">Subir</button>
              <a class="btn btn-outline-light" href="/catalogo">Ir al catálogo</a>
            </form>
          </div>
        </div>

        <div class="col-12 col-lg-6">
          <div class="adi-card p-3 p-md-4 h-100">
            <h2 class="h5 fw-bold mb-2">Resultado</h2>
            <div class="adi-soft small mb-3">
              Aquí verás la respuesta del API.
            </div>

            <pre
              id="out"
              class="mb-0"
              style="
                background: rgba(20,20,24,.92);
                color: #c7ffb2;
                border-radius: 1rem;
                padding: 14px;
                white-space: pre-wrap;
                min-height: 220px;
              "
            ></pre>
          </div>
        </div>
      </div>

      <div class="adi-soft small mt-3">
        Tip: si algo falla por CORS/auth, lo hacemos proxy SSR desde Astro.
      </div>

      <script define:vars={{ API_URL, token }}>
        const form = document.getElementById("bulkForm");
        const out = document.getElementById("out");

        form.addEventListener("submit", async (e) => {
          e.preventDefault();
          out.textContent = "Subiendo...";

          const fd = new FormData(form);

          const res = await fetch(`${API_URL}/products/bulk`, {
            method: "POST",
            headers: { Authorization: `Bearer ${token}` },
            body: fd,
          });

          const text = await res.text();
          out.textContent = `HTTP ${res.status}\n\n${text}`;
        });
      </script>
    </div>
  </section>
</BaseLayout>