---
export const prerender = false;

import BaseLayout from "../../layouts/BaseLayout.astro";
import { requireAdmin, logoutCookies } from "../../lib/requireAdmin";

const API_URL = import.meta.env.PUBLIC_API_URL ?? "http://localhost:3000";
const nextPath = "/admin/bulk";

const guard = requireAdmin(Astro);

if (!guard.ok) {
  // token missing/bad/expired/not_admin => logout real
  logoutCookies(Astro);
  return Astro.redirect(`/login?next=${encodeURIComponent(nextPath)}`);
}

const { token, email } = guard;
---

<BaseLayout title="ADI — Admin Bulk" menuMode="b2c" menuAnchors={false}>
  <section class="adi-section">
    <div class="container" style="max-width: 980px;">
      <div class="d-flex align-items-start justify-content-between gap-3 flex-wrap mb-3">
        <div>
          <div class="adi-soft small">Admin</div>
          <h1 class="fw-bold mb-1">Bulk Upload</h1>
          <div class="adi-soft">
            Sube el Excel y las imágenes referenciadas en <code>imageFiles</code>.
          </div>
          <div class="adi-soft small mt-1">
            Sesión: {email ?? "admin"} · rol: <span class="fw-semibold">admin</span>
          </div>
        </div>

        <a class="btn btn-outline-light" href="/account">Volver a cuenta</a>
      </div>

      <div class="row g-3">
        <div class="col-12 col-lg-6">
          <div class="adi-card p-3 p-md-4">
            <h2 class="h5 fw-bold mb-2">Subir archivos</h2>
            <div class="adi-soft small mb-3">
              El campo de imágenes es opcional. Puedes subir múltiples.
            </div>

            <form id="bulkForm" class="d-grid gap-3">
              <div>
                <label class="form-label">Excel (.xlsx)</label>
                <input class="form-control" name="file" type="file" accept=".xlsx" required />
              </div>

              <div>
                <label class="form-label">Imágenes (multiple)</label>
                <input class="form-control" name="images" type="file" accept="image/*" multiple />
              </div>

              <button class="btn btn-primary" type="submit">Subir</button>
              <a class="btn btn-outline-light" href="/catalogo">Ir al catálogo</a>
            </form>
          </div>
        </div>

        <div class="col-12 col-lg-6">
          <div class="adi-card p-3 p-md-4 h-100">
            <h2 class="h5 fw-bold mb-2">Resultado</h2>
            <div class="adi-soft small mb-3">
              Aquí verás la respuesta del API.
            </div>

            <pre
              id="out"
              class="mb-0"
              style="
                background: rgba(20,20,24,.92);
                color: #c7ffb2;
                border-radius: 1rem;
                padding: 14px;
                white-space: pre-wrap;
                min-height: 220px;
              "
            ></pre>
          </div>
        </div>
      </div>

      <div class="adi-soft small mt-3">
        Tip: si algo falla por CORS/auth, lo hacemos proxy SSR desde Astro.
      </div>

      <script define:vars={{ API_URL, token }}>
        const form = document.getElementById("bulkForm");
        const out = document.getElementById("out");

        form.addEventListener("submit", async (e) => {
          e.preventDefault();
          out.textContent = "Subiendo...";

          const fd = new FormData(form);

          const res = await fetch(`${API_URL}/products/bulk`, {
            method: "POST",
            headers: { Authorization: `Bearer ${token}` },
            body: fd,
          });

          const text = await res.text();
          out.textContent = `HTTP ${res.status}\n\n${text}`;
        });
      </script>
    </div>
  </section>
</BaseLayout>