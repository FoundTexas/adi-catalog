---
export const prerender = false;

import AppLayout from "../layouts/AppLayout.astro";

const API_URL = import.meta.env.PUBLIC_API_URL ?? "http://localhost:3000";
const isProd = import.meta.env.PROD;

const nextPath = "/account";

// SSR cookie header (más confiable que Astro.cookies en algunos setups SSR)
const cookieHeader = Astro.request.headers.get("cookie") ?? "";
const tokenMatch = cookieHeader.match(/(?:^|;\s*)adi_token=([^;]+)/);
const token = tokenMatch ? decodeURIComponent(tokenMatch[1]) : null;

let orders: any[] = [];
let ordersError = "";

// ---------- JWT helpers (SSR-safe) ----------
function decodeJwtPayloadSSR(jwt: string): any | null {
  try {
    const parts = jwt.split(".");
    if (parts.length < 2) return null;

    const payloadB64Url = parts[1];
    const pad = "=".repeat((4 - (payloadB64Url.length % 4)) % 4);
    const b64 = (payloadB64Url + pad).replace(/-/g, "+").replace(/_/g, "/");

    const json =
      typeof atob === "function"
        ? atob(b64)
        : Buffer.from(b64, "base64").toString("utf8");

    return JSON.parse(json);
  } catch {
    return null;
  }
}

function isTokenExpired(payload: any): boolean {
  const exp = payload?.exp;
  if (!exp) return false; // si no hay exp, no lo marcamos como expirado
  const nowSec = Math.floor(Date.now() / 1000);
  return Number(exp) <= nowSec;
}

function extractRole(payload: any): "admin" | "user" {
  const raw =
    payload?.role ??
    payload?.user?.role ??
    payload?.roles?.[0] ??
    payload?.user?.roles?.[0] ??
    null;

  if (!raw) return "user";
  const s = String(raw).toLowerCase();
  return s.includes("admin") ? "admin" : "user";
}

function extractEmail(payload: any): string | null {
  const raw =
    payload?.email ??
    payload?.user?.email ??
    payload?.username ??
    payload?.sub ??
    null;
  return raw ? String(raw) : null;
}

function logoutAndRedirect() {
  // borra cookies (path / para cubrir todo el sitio)
  Astro.cookies.delete("adi_token", { path: "/", secure: isProd, sameSite: "lax" });

  // cleanup por compatibilidad si existía antes
  Astro.cookies.delete("adi_user", { path: "/", secure: isProd, sameSite: "lax" });

  return Astro.redirect(`/login?next=${encodeURIComponent(nextPath)}`);
}

// ---------- Validate session ----------
if (!token) {
  return logoutAndRedirect();
}

const payload = decodeJwtPayloadSSR(token);
if (!payload) {
  return logoutAndRedirect();
}

if (isTokenExpired(payload)) {
  return logoutAndRedirect();
}

const role = extractRole(payload);
const email = extractEmail(payload) ?? "—";

// ---------- Load orders ----------
try {
  const res = await fetch(`${API_URL}/orders/me`, {
    headers: {
      Authorization: `Bearer ${token}`,
      Accept: "application/json",
    },
  });

  if (res.ok) {
    const data = await res.json();
    orders = Array.isArray(data) ? data : [];
  } else {
    // si es 401/403 probablemente token inválido en API → logout
    if (res.status === 401 || res.status === 403) return logoutAndRedirect();
    ordersError = `No se pudieron cargar pedidos (${res.status})`;
  }
} catch {
  ordersError = "No se pudieron cargar pedidos (error de red)";
}
---

<AppLayout title="ADI — Mi cuenta">
  <section class="adi-section">
    <div class="container" style="max-width: 980px;">
      <div class="d-flex align-items-start justify-content-between gap-3 flex-wrap mb-3">
        <div>
          <div class="adi-soft small">Cuenta</div>
          <h1 class="fw-bold mb-1">Mi cuenta</h1>
          <div class="adi-soft">
            {email} · rol: <span class="fw-semibold">{role}</span>
          </div>

          {/*
          // Debug opcional (quítalo en prod):
          <div class="adi-soft small mt-1">
            sub: {String(payload?.sub ?? "—")} · rawRole:{" "}
            {String(payload?.role ?? payload?.roles?.[0] ?? payload?.user?.role ?? payload?.user?.roles?.[0] ?? "—")}
          </div>
          */}
        </div>

        <form method="post" action="/logout" class="m-0">
          <button class="btn btn-outline-light" type="submit">Cerrar sesión</button>
        </form>
      </div>

      <div class="adi-card p-3 p-md-4 mb-3">
        <div class="d-flex gap-2 flex-wrap">
          <a class="btn btn-dark" href="/catalogo">Ir al catálogo</a>
          {role === "admin" && (
            <a class="btn btn-primary" href="/admin/bulk">Admin · Bulk Upload</a>
          )}
        </div>
      </div>

      <div class="adi-card p-3 p-md-4">
        <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-3">
          <h2 class="h5 fw-bold mb-0">Mis pedidos</h2>
          <div class="adi-soft small">{orders.length} pedidos</div>
        </div>

        {ordersError && <div class="alert alert-danger mb-0">{ordersError}</div>}

        {!ordersError && orders.length === 0 && (
          <div class="text-center adi-soft py-4">
            Aún no tienes pedidos.
          </div>
        )}

        {!ordersError && orders.length > 0 && (
          <div class="table-responsive">
            <table class="table align-middle mb-0">
              <thead>
                <tr>
                  <th>#</th>
                  <th>Status</th>
                  <th>Total</th>
                </tr>
              </thead>
              <tbody>
                {orders.map((o) => (
                  <tr>
                    <td class="fw-semibold">#{o.id}</td>
                    <td>{o.status}</td>
                    <td class="fw-semibold">
                      ${(Number(o.totalCents ?? 0) / 100).toFixed(2)} {o.currency ?? "MXN"}
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        )}
      </div>
    </div>
  </section>
</AppLayout>