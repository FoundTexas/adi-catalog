---
import Hero from "../components/Hero.astro";
import ProductsSection from "../components/ProductsSection.astro";
import PricingTable from "../components/PricingTable.astro";
import WorkGallery from "../components/WorkGallery.astro";
import DirectContact from "../components/DirectContact.astro";
import SideMenu from "../components/SideMenu.astro";
import BaseLayout from "../layouts/BaseLayout.astro";

const pageTitle =
  "ADI | Uniformes, merch y producción textil por volumen en México";

const pageDescription =
  "Producción textil por volumen para empresas, marcas y eventos en México. Playeras personalizadas, uniformes, merch y branding con atención directa.";

const canonical = "https://adi.foundtexas.net/";

const schema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: "ADI - Arte y Diseño Independiente",
  url: canonical,
  logo: "https://adi.foundtexas.net/ADI_mini.svg",
  description: pageDescription,
  areaServed: "MX",
};
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  canonical={canonical}
  schema={schema}
>
  <SideMenu />

  <Hero />

  <ProductsSection />

  <PricingTable />

  <WorkGallery />

  <DirectContact />
</BaseLayout>
