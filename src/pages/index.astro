---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import WorkGallery from "../components/WorkGallery.astro";
---

<BaseLayout title="ADI — Arte y Diseño Independiente">

  <Hero />

  <!-- SEPARADOR -->
  <div class="adi-divider container"></div>

  <WorkGallery />

  <!-- BLOQUE EXPLICATIVO -->
  <section class="adi-section">
    <div class="container text-center">

      <h2 class="fw-semibold mb-3">
        ¿Qué necesitas hoy?
      </h2>

      <div class="row g-4 mt-3">

        <!-- B2C -->
        <div class="col-md-6">
          <div class="adi-card p-4 h-100">
            <h4 class="fw-bold mb-2">Compra individual</h4>
            <p class="adi-soft mb-3">
              Compra por pieza directamente desde el catálogo.
            </p>
            <a href="/catalogo" class="btn btn-dark">
              Ver catálogo
            </a>
          </div>
        </div>

        <!-- B2B -->
        <div class="col-md-6">
          <div class="adi-card p-4 h-100">
            <h4 class="fw-bold mb-2">Producción para empresas</h4>
            <p class="adi-soft mb-3">
              Mayoreo, eventos, marcas y uniformes personalizados.
            </p>
            <a href="/b2b" class="btn btn-outline-dark">
              Cotizar volumen
            </a>
          </div>
        </div>

      </div>

    </div>
  </section>

</BaseLayout>