---
import ProductsCatalog from "./ProductsCatalog.tsx";
import { PRODUCTS } from "../config/pricing";
---

<section id="catalogo" class="adi-section">
  <div class="container">
    <div class="mb-3">
      <h2 class="fw-bold mb-1">Catálogo</h2>
      <div class="adi-soft">
        Selecciona un producto, elige color y consulta ficha técnica o tallas.
      </div>
    </div>

    <ProductsCatalog client:load products={PRODUCTS} />
  </div>
</section>