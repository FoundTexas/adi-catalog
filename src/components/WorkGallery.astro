---
type WorkImage = {
  src: string;
  width: number;
  height: number;
};

type WorkItem = {
  id: string; // folder slug
  title: string; // prettified folder name
  cover: WorkImage; // first image in folder
  images: WorkImage[]; // all images in folder
  sortKey: string;
};

// 1) Import everything under src/assets/works/<folder>/<file>
const workFiles = import.meta.glob<{ default: ImageMetadata }>(
  "../assets/works/*/*.{jpg,jpeg,png,webp,avif}",
  { eager: true },
);

// Helpers
const toTitle = (slug: string) =>
  slug
    .replace(/[-_]+/g, " ")
    .replace(/\s+/g, " ")
    .trim()
    .replace(/\b\w/g, (m) => m.toUpperCase());

const getFolder = (path: string) => {
  // .../works/<folder>/<file>
  const parts = path.split("/");
  return parts[parts.length - 2] ?? "work";
};

const getFile = (path: string) => path.split("/").pop() ?? "";

// 2) Group by folder
const byFolder = new Map<string, { path: string; img: ImageMetadata }[]>();

for (const [path, mod] of Object.entries(workFiles)) {
  const folder = getFolder(path);
  const arr = byFolder.get(folder) ?? [];
  arr.push({ path, img: (mod as any).default });
  byFolder.set(folder, arr);
}

// 3) Build items
const items: WorkItem[] = Array.from(byFolder.entries())
  .map(([folder, arr]) => {
    // sort files alphabetically to determine cover/ordering
    arr.sort((a, b) => getFile(a.path).localeCompare(getFile(b.path)));

    const images: WorkImage[] = arr.map(({ img }) => ({
      src: img.src,
      width: img.width,
      height: img.height,
    }));

    const cover = images[0];

    return {
      id: folder,
      title: toTitle(folder),
      cover,
      images,
      sortKey: folder.toLowerCase(),
    };
  })
  .sort((a, b) => a.sortKey.localeCompare(b.sortKey));
---

<section id="trabajos" class="adi-section adi-section-flow">
  <div class="container pb-4">
    <div class="mb-3">
      <h2 class="fw-bold mb-1">Trabajos realizados</h2>
      <div class="adi-soft">
        Ejemplos reales de estilos de impresión y producción.
      </div>
    </div>
  </div>

  <div class="adi-works-wrap" data-parallax-root>
    <div class="adi-works-grid" data-photo-grid>
      {
        items.map((w) => (
          <button
            type="button"
            class="adi-works-tile"
            data-parallax-tile
            data-work
            data-work-id={w.id}
            data-title={w.title}
            data-images={JSON.stringify(w.images.map((x) => x.src))}
            aria-label={`Ver trabajo: ${w.title}`}
          >
            <div class="adi-works-media" data-parallax-media>
              <img
                src={w.cover.src}
                width={w.cover.width}
                height={w.cover.height}
                alt={w.title}
                loading="lazy"
                decoding="async"
              />
            </div>

            <div class="adi-works-cap">
              <span>{w.title}</span>
            </div>
          </button>
        ))
      }
    </div>
  </div>

  {/* ONE GLOBAL WORK MODAL (slider) */}
  <div class="adi-photo-backdrop" data-work-modal hidden>
    <div
      class="adi-photo-modal"
      role="dialog"
      aria-modal="true"
      aria-label="Galería de trabajo"
    >
      <button
        class="adi-photo-close"
        type="button"
        data-work-close
        aria-label="Cerrar">✕</button
      >

      <div class="adi-work-head">
        <div class="adi-work-title" data-work-title>Trabajo</div>
        <div class="adi-work-counter" data-work-counter>1 / 1</div>
      </div>

      <div class="adi-work-stage">
        <button
          class="adi-work-nav is-prev"
          type="button"
          data-work-prev
          aria-label="Anterior">‹</button
        >
        <img class="adi-photo-img" data-work-img alt="" />
        <button
          class="adi-work-nav is-next"
          type="button"
          data-work-next
          aria-label="Siguiente">›</button
        >
      </div>

      <div class="adi-work-dots" data-work-dots></div>
    </div>
  </div>
</section>

<script is:inline>
  /* ===========================
     Parallax (strong, per tile)
  =========================== */
  const clamp = (n, a, b) => Math.max(a, Math.min(b, n));
  const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  const root = document.querySelector("[data-parallax-root]");
  if (root && !reduce) {
    const tiles = Array.from(root.querySelectorAll("[data-parallax-tile]"));
    const active = new Set();
    let raf = 0;

    const io = new IntersectionObserver(
      (entries) => {
        for (const e of entries) {
          if (e.isIntersecting) active.add(e.target);
          else active.delete(e.target);
        }
        requestTick();
      },
      { threshold: 0.01 },
    );

    tiles.forEach((t) => io.observe(t));

    const update = () => {
      raf = 0;
      const vh = window.innerHeight || 1;

      for (const tile of active) {
        const media = tile.querySelector("[data-parallax-media]");
        if (!media) continue;

        const rect = tile.getBoundingClientRect();
        const progress = (vh - rect.top) / (vh + rect.height);
        const p = clamp(progress, 0, 1);
        const centered = (p - 0.5) * 2; // [-1..1]

        // Exaggerated depth
        const depthY = 200;
        const driftX = 0;
        const baseScale = 0.9;

        const y = centered * depthY;
        const x = centered * driftX;
        const s = baseScale + Math.abs(centered) * 0.07;

        media.style.setProperty("--px", x.toFixed(2) + "px");
        media.style.setProperty("--py", y.toFixed(2) + "px");
        media.style.setProperty("--pz", s.toFixed(3));
      }
    };

    const requestTick = () => {
      if (raf) return;
      raf = requestAnimationFrame(update);
    };

    window.addEventListener("scroll", requestTick, { passive: true });
    window.addEventListener("resize", requestTick);
    requestTick();
  }

  /* ===========================
     Modal + Slider
  =========================== */
  const grid = document.querySelector("[data-photo-grid]");
  const modal = document.querySelector("[data-work-modal]");
  const img = document.querySelector("[data-work-img]");
  const closeBtn = document.querySelector("[data-work-close]");
  const prevBtn = document.querySelector("[data-work-prev]");
  const nextBtn = document.querySelector("[data-work-next]");
  const titleEl = document.querySelector("[data-work-title]");
  const counterEl = document.querySelector("[data-work-counter]");
  const dotsEl = document.querySelector("[data-work-dots]");

  let currentImages = [];
  let idx = 0;
  let lastFocus = null;

  const setBodyLock = (lock) => {
    if (lock) {
      const prev = document.body.style.overflow;
      document.body.dataset.prevOverflow = prev || "";
      document.body.style.overflow = "hidden";
      return;
    }
    document.body.style.overflow = document.body.dataset.prevOverflow || "";
    delete document.body.dataset.prevOverflow;
  };

  const renderDots = () => {
    if (!dotsEl) return;
    dotsEl.innerHTML = "";
    currentImages.forEach((_, i) => {
      const b = document.createElement("button");
      b.type = "button";
      b.className = "adi-dot" + (i === idx ? " is-active" : "");
      b.setAttribute("aria-label", `Ir a imagen ${i + 1}`);
      b.addEventListener("click", () => go(i));
      dotsEl.appendChild(b);
    });
  };

  const updateUI = (title) => {
    if (titleEl) titleEl.textContent = title || "Trabajo";
    if (counterEl)
      counterEl.textContent = `${idx + 1} / ${currentImages.length || 1}`;
    if (prevBtn) prevBtn.disabled = currentImages.length <= 1;
    if (nextBtn) nextBtn.disabled = currentImages.length <= 1;
    renderDots();
  };

  const go = (next) => {
    if (!currentImages.length) return;
    idx = (next + currentImages.length) % currentImages.length;
    const src = currentImages[idx];
    if (img) img.src = src;
    // keep alt as title; set in open()
    updateUI(titleEl?.textContent || "");
  };

  const open = (images, title) => {
    currentImages = images || [];
    idx = 0;

    if (!img) return;
    img.src = currentImages[0] || "";
    img.alt = title || "Trabajo";

    if (modal) modal.hidden = false;
    updateUI(title);

    lastFocus = document.activeElement;
    setBodyLock(true);
    closeBtn?.focus();
  };

  const close = () => {
    if (!modal || !img) return;
    modal.hidden = true;
    img.src = "";
    currentImages = [];
    idx = 0;

    setBodyLock(false);
    if (lastFocus && typeof lastFocus.focus === "function") lastFocus.focus();
  };

  grid?.addEventListener("click", (e) => {
    const btn = e.target.closest("[data-work]");
    if (!btn) return;

    const title = btn.getAttribute("data-title") || "Trabajo";
    let images = [];
    try {
      images = JSON.parse(btn.getAttribute("data-images") || "[]");
    } catch {}
    open(images, title);
  });

  closeBtn?.addEventListener("click", close);
  modal?.addEventListener("click", (e) => {
    if (e.target === modal) close();
  });

  prevBtn?.addEventListener("click", () => go(idx - 1));
  nextBtn?.addEventListener("click", () => go(idx + 1));

  window.addEventListener("keydown", (e) => {
    if (!modal || modal.hidden) return;

    if (e.key === "Escape") return close();
    if (e.key === "ArrowLeft") return go(idx - 1);
    if (e.key === "ArrowRight") return go(idx + 1);
  });

  // Basic swipe (mobile)
  let sx = 0,
    sy = 0,
    tracking = false;
  const stage = document.querySelector(".adi-work-stage");
  stage?.addEventListener("pointerdown", (e) => {
    tracking = true;
    sx = e.clientX;
    sy = e.clientY;
  });
  stage?.addEventListener("pointerup", (e) => {
    if (!tracking) return;
    tracking = false;

    const dx = e.clientX - sx;
    const dy = e.clientY - sy;

    if (Math.abs(dx) < 35 || Math.abs(dx) < Math.abs(dy)) return;
    if (dx > 0) go(idx - 1);
    else go(idx + 1);
  });
</script>

<style>
  /* ======================================================
     WorkGallery — COMPLETE STYLE (REVISED)
     - Sharp rectangles (no radius)
     - Parallax layer inside tiles
     - Modal shows FULL image (no crop)
     - No overflow (grid + modal fixed)
  ====================================================== */

  /* Section flow */
  .adi-section-flow {
    display: block;
    min-height: auto;
    padding: 6rem 0;
  }

  /* Full-width wrap */
  .adi-works-wrap {
    width: 100%;
    margin-top: 1rem;
    padding: 0 12px;
  }
  @media (min-width: 576px) {
    .adi-works-wrap {
      padding: 0 16px;
    }
  }
  @media (min-width: 992px) {
    .adi-works-wrap {
      padding: 0 24px;
    }
  }

  /* Grid */
  .adi-works-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 12px;
  }
  @media (min-width: 768px) {
    .adi-works-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 14px;
    }
  }
  @media (min-width: 1200px) {
    .adi-works-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 16px;
    }
  }

  /* Tile */
  .adi-works-tile {
    position: relative;
    margin: 0;
    padding: 0;

    border-radius: 0;
    border: 1px solid rgba(120, 90, 160, 0.18);
    background: rgba(255, 255, 255, 0.7);
    box-shadow: 0 18px 60px rgba(100, 60, 150, 0.1);

    overflow: hidden;

    /* tweak this to make cards more squared/rectangular */
    aspect-ratio: 5 / 4;
    height: auto;

    cursor: zoom-in;
    text-align: left;
    appearance: none;
    width: 100%;

    transition:
      transform 0.25s ease,
      box-shadow 0.25s ease,
      border-color 0.25s ease;
  }

  .adi-works-tile:hover {
    transform: translateY(-4px);
    border-color: rgba(180, 108, 255, 0.4);
    box-shadow: 0 30px 95px rgba(100, 60, 150, 0.16);
  }

  .adi-works-tile:focus-visible {
    outline: 3px solid rgba(180, 108, 255, 0.35);
    outline-offset: 3px;
  }

  /* Parallax layer */
  .adi-works-media {
    position: absolute;
    inset: -33%;
    --px: 0px;
    --py: 0px;
    --pz: 0;

    transform: translate3d(var(--px), var(--py), 0) scale(var(--pz));
    will-change: transform;
    filter: saturate(1) contrast(1.1);
  }

  .adi-works-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transform: translateZ(0);
  }

  /* Depth overlays */
  .adi-works-tile::before {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      linear-gradient(180deg, rgba(0, 0, 0, 0.3), rgba(0, 0, 0, 0) 45%),
      radial-gradient(
        120% 100% at 50% 10%,
        rgba(255, 255, 255, 0.12),
        rgba(255, 255, 255, 0) 60%
      );
    opacity: 0.92;
    z-index: 2;
  }

  .adi-works-tile::after {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: radial-gradient(
      120% 120% at 50% 60%,
      rgba(0, 0, 0, 0),
      rgba(0, 0, 0, 0.32)
    );
    opacity: 0.78;
    z-index: 2;
  }

  /* Caption */
  .adi-works-cap {
    position: absolute;
    left: 12px;
    right: 12px;
    bottom: 12px;
    z-index: 3;

    padding: 0.7rem 0.95rem;
    border-radius: 0;

    border: 1px solid rgba(255, 255, 255, 0.55);
    background: rgba(255, 255, 255, 0.62);
    backdrop-filter: blur(10px);

    color: #2a1f40;
    font-weight: 800;

    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  /* ======================================================
     MODAL + SLIDER (FULL IMAGE, NO CROP)
  ====================================================== */

  /* Backdrop */
  .adi-photo-backdrop {
    position: fixed;
    inset: 0;
    z-index: 2147483647;

    background: rgba(20, 10, 35, 0.72);
    backdrop-filter: blur(10px);

    display: flex;
    align-items: center;
    justify-content: center;

    padding: 16px;
  }

  /* Modal box */
  .adi-photo-modal {
    position: relative;
    width: min(1200px, 96vw);
    height: min(88vh, 920px);

    background: rgba(0, 0, 0, 0.85);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 0;

    overflow: hidden; /* ✅ clip everything */
    box-shadow: 0 50px 150px rgba(0, 0, 0, 0.35);

    display: grid;
    grid-template-rows: auto 1fr auto;

    /* ✅ prevents grid children from forcing overflow */
    min-width: 0;
    min-height: 0;
  }

  /* Header */
  .adi-work-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;

    padding: 12px 14px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    color: #fff;

    min-width: 0;
  }

  .adi-work-title {
    font-weight: 900;
    letter-spacing: 0.02em;

    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    min-width: 0;
  }

  .adi-work-counter {
    font-size: 12px;
    opacity: 0.85;
    white-space: nowrap;
  }

  /* Stage (IMPORTANT FIX: flex centers and avoids crop) */
  .adi-work-stage {
    position: relative;

    display: flex;
    align-items: center;
    justify-content: center;

    /* ✅ prevents expanding the grid row */
    min-height: 0;
    min-width: 0;

    /* ✅ ensures nothing spills out */
    overflow: hidden;

    background: #111;
    user-select: none;
    touch-action: pan-y;
  }

  /* Image (FULLY visible, never cropped) */
  .adi-photo-img {
    display: block;

    /* ✅ keep entire image visible */
    max-width: 100%;
    max-height: 100%;

    width: auto;
    height: auto;

    object-fit: contain;

    background: rgba(0, 0, 0, 0.2);
  }

  /* Nav */
  .adi-work-nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);

    width: 44px;
    height: 44px;

    border: 0;
    border-radius: 0;
    cursor: pointer;

    background: rgba(0, 0, 0, 0.55);
    color: #fff;
    font-size: 28px;

    display: grid;
    place-items: center;

    transition:
      transform 0.2s ease,
      background-color 0.2s ease,
      opacity 0.2s ease;

    z-index: 2;
  }

  .adi-work-nav:hover {
    transform: translateY(-50%) scale(1.04);
    background: rgba(0, 0, 0, 0.75);
  }

  .adi-work-nav:disabled {
    opacity: 0.35;
    cursor: default;
  }

  .adi-work-nav.is-prev {
    left: 10px;
  }
  .adi-work-nav.is-next {
    right: 10px;
  }

  /* Dots */
  .adi-work-dots {
    display: flex;
    gap: 8px;
    justify-content: center;
    align-items: center;

    padding: 12px 14px;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    background: rgba(0, 0, 0, 0.45);
  }

  .adi-dot {
    width: 10px;
    height: 10px;

    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.35);
    background: rgba(255, 255, 255, 0.1);

    cursor: pointer;
    padding: 0;
  }

  .adi-dot.is-active {
    background: rgba(255, 255, 255, 0.85);
    border-color: rgba(255, 255, 255, 0.85);
  }

  /* Close button */
  .adi-photo-close {
    position: absolute;
    top: 10px;
    right: 10px;

    width: 42px;
    height: 42px;

    border: 0;
    border-radius: 0;
    cursor: pointer;

    background: rgba(0, 0, 0, 0.7);
    color: #fff;
    font-size: 18px;
    line-height: 1;

    display: grid;
    place-items: center;

    transition:
      transform 0.2s ease,
      background-color 0.2s ease;

    z-index: 3;
  }

  .adi-photo-close:hover {
    transform: translateY(-1px);
    background: rgba(0, 0, 0, 0.86);
  }

  /* Mobile tweaks */
  @media (max-width: 520px) {
    .adi-work-nav {
      width: 40px;
      height: 40px;
      font-size: 24px;
    }
  }

  /* Reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .adi-works-media {
      transform: none !important;
      inset: 0;
      will-change: auto;
    }
  }
</style>
