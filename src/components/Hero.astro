---
import { PRICING } from "../config/pricing";
---

<section class="adi-section pt-5">
  <div class="container" id="hero">
    <div
      class="row align-items-center justify-content-center justify-content-md-start g-4"
    >
      <!-- TEXTO -->
      <div class="col-12 col-lg-6 text-center text-lg-start">
        <div class="mt-4">
          <a
            href="/"
            class="adi-catalog-logo d-inline-block mb-3"
            aria-label="Volver al inicio de ADI"
          >
            <img
              src="/ADI_full.svg"
              alt="ADI — Arte y Diseño Independiente"
              width="auto"
              height="70rem"
              loading="eager"
            />
          </a>
        </div>

        <div class="text-uppercase small fw-semibold adi-soft mb-2">
          Arte y Diseño Independiente
        </div>

        <h1 class="fw-bold mb-3">
          Uniformes, playeras y textiles personalizados
        </h1>

        <p class="adi-subtitle mb-4">
          Playeras, polos, sudaderas, hoodies, uniformes
          y tote bags mediante bordado e impresión DTF, desde {
            PRICING.wholesaleThreshold
          } piezas y con envíos a todo México.
        </p>

        <div
          class="d-flex flex-wrap gap-2 mb-4 justify-content-center justify-content-lg-start"
        >
          <span class="badge text-bg-dark border">Uniformes y merch</span>
          <span class="badge text-bg-dark border">Producción local</span>
        </div>

        <div
          class="d-flex flex-wrap gap-3 mb-3 justify-content-center justify-content-lg-start"
        >
          <a
            class="btn btn-primary btn-lg"
            href="#precios"
            data-scroll-target="precios"
          >
            Ver precios
          </a>

          <a
            class="btn btn-outline-dark btn-lg"
            href="#catalogo"
            data-scroll-target="catalogo"
          >
            Ver catálogo
          </a>
        </div>

        <div class="adi-soft small">
          Ideal para empresas, eventos, equipos, marcas emergentes, artistas
          independientes, campañas corporativas, merch, activaciones y branding.
        </div>
      </div>

      <!-- IMÁGENES + PROCESO -->
      <div class="col-lg-6">
        <div class="row g-3">
          <!-- imagen principal -->
          <div class="col-12 m-3">
            <div class="adi-b2b-card overflow-hidden">
              <img
                src="/img/hero/adi-hero-main.webp"
                alt="Hoodie personalizada ADI"
                class="img-fluid rounded-4 my-3"
                width="900"
                height="620"
                loading="eager"
              />
            </div>
          </div>
        </div>
      </div>

      <!-- EJEMPLO B2B -->
      <div class="col-12">
        <div
          class="row align-items-center g-4 mt-2 flex-column-reverse flex-lg-row"
        >
          <div class="col-lg-6 col-12 p-0">
            <div class="row g-1 align-items-stretch" style="height: 420px;">
              <div class="col-4 d-flex overflow-hidden">
                <img
                  src="/img/b2b/B2Bproc1.webp"
                  alt="Producción textil para empresas y eventos"
                  class="w-100 h-100 object-fit-cover rounded-4"
                  loading="lazy"
                />
              </div>

              <div class="col-4 d-flex overflow-hidden">
                <img
                  src="/img/b2b/B2Bproc2.webp"
                  alt="Bordado personalizado"
                  class="w-100 h-100 object-fit-cover rounded-4"
                  loading="lazy"
                />
              </div>

              <div class="col-4 d-flex overflow-hidden">
                <img
                  src="/img/b2b/B2Bproc3.webp"
                  alt="Estampado personalizado"
                  class="w-100 h-100 object-fit-cover rounded-4"
                  loading="lazy"
                />
              </div>
            </div>
          </div>

          <div class="col-lg-6">
            <h2 class="fw-semibold mb-3 text-center text-md-start">
              ¿Cómo trabajamos?
            </h2>

            <div class="d-grid gap-3 mb-0">
              <div class="bg-dark text-light border rounded-4 p-3">
                <div class="small text-uppercase opacity-75 mb-1">Paso 1</div>
                <div class="fw-semibold">Eliges producto y cantidades</div>
              </div>

              <div class="bg-dark text-light border rounded-4 p-3">
                <div class="small text-uppercase opacity-75 mb-1">Paso 2</div>
                <div class="fw-semibold">Nos compartes tu logo o idea</div>
              </div>

              <div class="bg-dark text-light border rounded-4 p-3">
                <div class="small text-uppercase opacity-75 mb-1">Paso 3</div>
                <div class="fw-semibold">Te cotizamos y producimos</div>
              </div>
            </div>

            <hr class="my-3" />

            <div class="adi-soft small">
              Producción local · Comunicación directa · Proyectos por volumen
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script>
    const scrollButtons = Array.from(
      document.querySelectorAll("[data-scroll-target]"),
    );

    scrollButtons.forEach((button) => {
      button.addEventListener("click", (event) => {
        event.preventDefault();

        const id = button.getAttribute("data-scroll-target");
        const section = id ? document.getElementById(id) : null;

        if (!section) return;

        section.scrollIntoView({
          behavior: "smooth",
          block: "start",
        });

        history.replaceState(
          null,
          "",
          window.location.pathname + window.location.search,
        );
      });
    });
  </script>
</section>
