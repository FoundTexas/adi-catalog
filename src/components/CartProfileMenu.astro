---
import CartFab from "./cart/CartFab.astro";
import CartProfilePanel from "./cart/CartProfilePanel.astro";
import CartPanel from "./cart/CartPanel.astro";

const {
  loginHref = "/login",
  logoutHref = "/logout",
  ordersHref = "/account",
  bulkHref = "/admin/bulk",
  catalogHref = "/catalogo",
  checkoutHref = "/checkout",
} = Astro.props;
---

<CartFab targetId="adiSidePanel" />

<div class="offcanvas offcanvas-end" tabindex="-1" id="adiSidePanel" aria-labelledby="adiSidePanelLabel">
  <div class="offcanvas-header">
    <div>
      <div class="adi-soft small">ADI</div>
      <h5 class="offcanvas-title" id="adiSidePanelLabel">Carrito & Perfil</h5>
    </div>
    <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Cerrar"></button>
  </div>

  <div class="offcanvas-body">
    <CartProfilePanel
      loginHref={loginHref}
      logoutHref={logoutHref}
      ordersHref={ordersHref}
      bulkHref={bulkHref}
    />
    <CartPanel catalogHref={catalogHref} checkoutHref={checkoutHref} />
  </div>
</div>

<style>
  .offcanvas { background: var(--adi-bg); color: var(--adi-text); }
</style>

<script is:inline>
  // hide FAB while panel open
  document.addEventListener("shown.bs.offcanvas", (e) => {
    if (e?.target?.id === "adiSidePanel") {
      document.querySelector(".adi-fab")?.classList.add("is-hidden");
    }
  });
  document.addEventListener("hidden.bs.offcanvas", (e) => {
    if (e?.target?.id === "adiSidePanel") {
      document.querySelector(".adi-fab")?.classList.remove("is-hidden");
    }
  });
</script>

<style>
  .adi-fab.is-hidden { opacity: 0; pointer-events: none; transform: translateY(-6px); }
</style>