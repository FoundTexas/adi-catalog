---
const { targetId = "adiSidePanel" } = Astro.props;
---

<button
  class="adi-fab"
  type="button"
  data-bs-toggle="offcanvas"
  data-bs-target={`#${targetId}`}
  aria-controls={targetId}
  title="Carrito / Perfil"
>
  <span class="adi-fabSvg" aria-hidden="true">
    <svg fill="#ffffff" viewBox="-1.5 0 19 19" xmlns="http://www.w3.org/2000/svg" class="cf-icon-svg">
      <path
        d="M14.252 4.59a.924.924 0 0 1 .921.92v3.602a1.048 1.048 0 0 1-.916 1.017l-8.511.883a.573.573 0 0 1-.145.019.577.577 0 1 0 0 1.154h8.488a.563.563 0 1 1 0 1.126h-.91a1.03 1.03 0 1 1-1.104 0H6.849a1.03 1.03 0 1 1-1.104 0H5.6a1.703 1.703 0 1 1 0-3.406.585.585 0 0 1 .128.014L3.111 3.911H1.39a.563.563 0 1 1 0-1.125h2.09a.562.562 0 0 1 .515.337l.64 1.466h9.617z"
      />
    </svg>
  </span>

  <span class="adi-fabBadge" id="adiFabCount" style="display:none;">0</span>
</button>

<style>
  .adi-fab {
    position: fixed; top: 16px; right: 16px; z-index: 1049;
    width: 52px; height: 52px;
    display: inline-flex; align-items: center; justify-content: center;
    border-radius: 999px !important;
    background: rgba(20, 20, 24, 0.88); color: #fff;
    border: 1px solid rgba(255, 255, 255, 0.12);
    box-shadow: var(--adi-shadow);
    backdrop-filter: blur(8px);
    cursor: pointer;
    transition: transform 0.18s ease, box-shadow 0.18s ease, border-color 0.18s ease;
  }
  .adi-fab:hover { transform: translateY(-2px); border-color: var(--adi-accent-soft); }
  .adi-fabSvg { width: 22px; height: 22px; display: inline-flex; align-items: center; justify-content: center; }
  .adi-fabSvg svg { width: 22px; height: 22px; display: block; }
  .adi-fabBadge {
    position: absolute; top: -6px; right: -6px;
    font-size: 11px; padding: 2px 7px; border-radius: 999px;
    background: linear-gradient(135deg, var(--adi-accent), #8e5bff);
    color: #fff;
    border: 1px solid rgba(255, 255, 255, 0.6);
  }
</style>