---
const { title = "ADI", menuMode = "b2c", menuAnchors = false } = Astro.props;
import "../styles/global.css";
import TopMenu from "../components/TopMenu.astro";
import DirectContact from "../components/DirectContact.astro";
import CartProfileMenu from "../components/CartProfileMenu.astro";
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>

    <!-- Basic -->
    <meta
      name="description"
      content="Playeras, hoodies y sudaderas personalizadas. Producción premium y atención directa."
    />

    <!-- Open Graph (Facebook, WhatsApp, iMessage, etc.) -->
    <meta property="og:title" content="ADI — Arte y Diseño Independiente" />
    <meta
      property="og:description"
      content="Playeras, hoodies y sudaderas personalizadas. Producción premium y atención directa."
    />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://adi.foundtexas.net/" />
    <meta
      property="og:image"
      content="https://adi.foundtexas.net/ADI_mini.svg"
    />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="ADI — Arte y Diseño Independiente" />
    <meta
      name="twitter:description"
      content="Playeras, hoodies y sudaderas personalizadas. Producción premium y atención directa."
    />
    <meta
      name="twitter:image"
      content="https://adi.foundtexas.net/ADI_mini.svg"
    />

    <!-- Favicon SVG -->
    <link rel="icon" type="image/svg+xml" href="/ADI_mini.svg" />

    <!-- Bootstrap CSS -->
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
  </head>

  <body class="adi-bg">
    <CartProfileMenu user={Astro.locals.user} />
    <TopMenu mode={menuMode} showAnchors={menuAnchors} />
    <main>
      <slot />
    </main>

    <DirectContact />

    <!-- Bootstrap JS -->
    <script
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
      defer></script>
  </body>
</html>
