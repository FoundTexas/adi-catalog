---
const {
  title = "Uniformes y playeras personalizadas en CDMX | ADI",
  description = "Personalizamos playeras, polos, uniformes, sudaderas, hoodies, scrubs y tote bags con bordado y DTF en CDMX. Pedidos desde 5 piezas y envíos en México.",
  image = "https://adi.foundtexas.net/og/adi-og-home.jpg",
  canonical = "https://adi.foundtexas.net/",
  noIndex = false,
  schema = null,
  ogType = "website",
} = Astro.props;

const robotsContent = noIndex
  ? "noindex, nofollow"
  : "index, follow, max-image-preview:large";

import "../styles/global.css";
---

<!doctype html>
<html lang="es-MX">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>{title}</title>
    <meta name="description" content={description} />

    <meta name="author" content="ADI - Arte y Diseño Independiente" />
    <meta name="robots" content={robotsContent} />

    <link rel="canonical" href={canonical} />

    <meta name="theme-color" content="#f6f3fb" />

    <!-- Open Graph -->
    <meta property="og:locale" content="es_MX" />
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="ADI - Arte y Diseño Independiente" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={image} />
    <meta
      property="og:image:alt"
      content="ADI - producción textil, uniformes y merch personalizado en México"
    />

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />

    <!-- Icons -->
    <link rel="icon" type="image/svg+xml" href="/ADI_mini.svg" />

    <!-- Performance -->
    <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />

    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />

    {
      schema && (
        <script type="application/ld+json" set:html={JSON.stringify(schema)} />
      )
    }
  </head>

  <body class="adi-bg">
    <main>
      <slot />
    </main>

    <script
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
    ></script>
  </body>
</html>
